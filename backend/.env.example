PORT=5000
# If your password has @ # ? etc., URL-encode them (e.g. @ → %40)
MONGO_URI=mongodb://127.0.0.1:27017/real_estate_platform
# Optional: standard Atlas URI (three hosts, tls=true, replicaSet=...) — use when mongodb+srv causes querySrv ECONNREFUSED in Node
# MONGO_URI_DIRECT=mongodb://USER:PASS@host0:27017,host1:27017,host2:27017/DB?tls=true&authSource=admin&replicaSet=atlas-xxxxx-shard-0
JWT_SECRET=replace_with_a_long_random_secret
# Optional: auto-create / promote admin on server start (set both)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change_me_strong_password
# Comma-separated allowed origins (optional). Defaults include localhost + 127.0.0.1:5173
CLIENT_ORIGIN=http://localhost:5173
# CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

